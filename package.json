{
  "name": "@sha3/polymarket-quant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "start": "node --import tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run standards:check && npm run lint && npm run format:check && npm run typecheck && npm run test",
    "fix": "npm run lint:fix && npm run format:write",
    "lint": "biome check src test public README.md package.json .biomeignore",
    "lint:fix": "biome check src test public README.md package.json .biomeignore --write",
    "format:check": "biome format src test public README.md package.json .biomeignore",
    "format:write": "biome format src test public README.md package.json .biomeignore --write",
    "standards:check": "code-standards verify",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "publish": "node scripts/release-publish.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@sha3/crypto": "^1.1.0",
    "@sha3/logger": "^2.0.0",
    "@sha3/polymarket": "^1.11.0",
    "@sha3/polymarket-snapshot": "^2.3.0",
    "dotenv": "^16.6.1",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@sha3/code-standards": "^1.4.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sha3dev/polymarket-quant"
  },
  "codeStandards": {
    "template": "node-service",
    "profilePath": null,
    "withAiAdapters": true,
    "lastRefactorWith": "1.4.0",
    "contractVersion": "v2"
  }
}
